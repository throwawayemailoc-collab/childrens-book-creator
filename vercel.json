{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/generate-text", "destination": "/api/generate-text" },
    { "source": "/api/generate-image", "destination": "/api/generate-image" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
